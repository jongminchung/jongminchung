{
  "name": "@jongminchung/ui",
  "version": "1.0.0",
  "description": "OSS-neutral Tailwind and React design primitives",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jongminchung/jongminchung.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "src/index.ts",
    "src/design-system.ts",
    "src/styles.css",
    "src/baseline.css",
    "src/components/ui/badge.tsx",
    "src/components/ui/button.tsx",
    "src/components/ui/card.tsx",
    "src/lib/utils.ts",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "./dist/baseline.css",
    "./src/styles.css",
    "./src/baseline.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": {
      "source": "./src/styles.css",
      "default": "./dist/styles.css"
    },
    "./tokens.css": {
      "source": "./src/styles.css",
      "default": "./dist/styles.css"
    },
    "./baseline.css": {
      "source": "./src/baseline.css",
      "default": "./dist/baseline.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsdown --log-level error --no-report",
    "prepack": "pnpm run build",
    "publish:dry-run": "pnpm publish --dry-run --access public",
    "test": "vitest run --root ../.. packages/ui",
    "typecheck": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tsdown": "^0.22.7",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "nx": {
    "tags": [
      "pkg:ui"
    ]
  }
}
