{
  "name": "@jongminchung/immersive-translate",
  "version": "1.0.0",
  "private": true,
  "description": "Local bilingual webpage and video caption translation Chrome extension",
  "type": "module",
  "scripts": {
    "build": "pnpm run icon:check && wxt build",
    "clean": "pnpm node scripts/clean.ts",
    "dev": "pnpm run icon:check && wxt",
    "docker:build": "docker compose -f docker/docker-compose.yml build gateway",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f gateway libretranslate",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d --build",
    "docker:up:mlx": "TRANSLATION_PROFILE=mlx docker compose -f docker/docker-compose.yml up -d --build gateway",
    "icon:check": "pnpm --dir ../.. run icon:check",
    "mlx:serve": "sh scripts/run-mlx-server.sh",
    "mlx:serve:detach": "sh scripts/run-mlx-server-detached.sh",
    "mlx:serve:logs": "tail -f .output/mlx-server.log",
    "mlx:serve:stop": "sh scripts/stop-mlx-server.sh",
    "test:live": "pnpm run build && playwright test -c playwright.config.ts tests/live/immersive-translate.spec.ts",
    "test:unit": "vitest run --config vitest.config.ts src/lib gateway",
    "typecheck": "wxt prepare && tsc --noEmit && tsc --noEmit --project gateway/tsconfig.json",
    "verify:artifacts": "pnpm run icon:check && pnpm node scripts/verify-extension-artifacts.ts",
    "zip": "pnpm run icon:check && wxt zip"
  },
  "dependencies": {
    "@astryxdesign/core": "0.1.5",
    "@astryxdesign/theme-neutral": "0.1.5",
    "@stylexjs/stylex": "0.19.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "tailwindcss": "^4.3.2",
    "typescript": "6.0.3",
    "vitest": "^4.1.9",
    "wxt": "^0.20.27"
  }
}
