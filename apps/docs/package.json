{
  "name": "@jongminchung/docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/prepare-excalidraw-assets.ts && node scripts/check-excalidraw.ts && pnpm run content:check && next build",
    "content:build": "node scripts/build-content.ts --write",
    "content:check": "node scripts/build-content.ts --check",
    "dev": "node scripts/prepare-excalidraw-assets.ts && next dev",
    "excalidraw:assets": "node scripts/prepare-excalidraw-assets.ts",
    "excalidraw:check": "node scripts/check-excalidraw.ts",
    "start": "next start",
    "test": "vitest run --root ../.. apps/docs",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.1",
    "@jongminchung/icon": "workspace:*",
    "@jongminchung/ui": "workspace:*",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "16.2.10",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "catalog:",
    "@types/mdx": "2.0.14",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "gray-matter": "4.0.3",
    "postcss": "catalog:",
    "rehype-slug": "6.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-mdx-frontmatter": "5.2.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
