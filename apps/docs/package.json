{
  "name": "@jongminchung/docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run icon:check && node scripts/build-content.ts && tsc --noEmit && next build",
    "dev": "pnpm run icon:check && node scripts/build-content.ts && next dev",
    "icon:check": "pnpm --dir ../.. run icon:check",
    "start": "next start",
    "test": "vitest run --root ../.. apps/docs",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astryxdesign/core": "0.1.5",
    "@astryxdesign/theme-neutral": "0.1.5",
    "@jongminchung/icon": "workspace:*",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "16.2.10",
    "@stylexjs/stylex": "0.19.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "catalog:",
    "@types/mdx": "2.0.14",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "gray-matter": "4.0.3",
    "postcss": "catalog:",
    "rehype-slug": "6.0.0",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-mdx-frontmatter": "5.2.0",
    "typescript": "catalog:",
    "vitest": "4.1.9"
  }
}
