{
  "name": "@jongminchung/git-client",
  "version": "0.1.0",
  "private": true,
  "description": "A lightweight IntelliJ-style Git client for macOS",
  "type": "module",
  "scripts": {
    "benchmark": "node scripts/benchmark.mjs",
    "bindings:check": "cargo test --manifest-path src-tauri/Cargo.toml export_bindings && git diff --exit-code -- src/generated",
    "build": "tsc --noEmit && vite build",
    "dev": "vite",
    "release": "node scripts/publish-release.mjs",
    "release:build": "node scripts/release.mjs",
    "release:dry-run": "node scripts/publish-release.mjs --dry-run",
    "release:verify-first": "node scripts/verify-first-release.mjs",
    "rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings && cargo test --manifest-path src-tauri/Cargo.toml",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:dev": "tauri dev",
    "test": "vitest run --root ../.. apps/git-client",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "catalog:",
    "@codemirror/lang-css": "catalog:",
    "@codemirror/lang-html": "catalog:",
    "@codemirror/lang-java": "catalog:",
    "@codemirror/lang-javascript": "catalog:",
    "@codemirror/lang-json": "catalog:",
    "@codemirror/lang-python": "catalog:",
    "@codemirror/language": "catalog:",
    "@codemirror/merge": "catalog:",
    "@codemirror/search": "catalog:",
    "@codemirror/state": "catalog:",
    "@codemirror/view": "catalog:",
    "@tanstack/react-virtual": "catalog:",
    "@tauri-apps/api": "catalog:",
    "@tauri-apps/plugin-dialog": "catalog:",
    "@tauri-apps/plugin-opener": "catalog:",
    "@tauri-apps/plugin-store": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@playwright/test": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "nx": {
    "targets": {
      "release": {
        "inputs": [
          "{projectRoot}/**/*",
          "{workspaceRoot}/.github/workflows/git-client.yml"
        ]
      }
    }
  }
}
