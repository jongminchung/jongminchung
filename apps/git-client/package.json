{
  "name": "@jongminchung/git-client",
  "version": "0.1.0",
  "private": true,
  "description": "An Electron Git and forge client for macOS with Rebased 1.1.8 parity",
  "type": "module",
  "main": ".vite/build/main.cjs",
  "scripts": {
    "benchmark": "node scripts/benchmark.mjs",
    "build": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json && vite build",
    "dev": "electron-forge start",
    "electron:make": "electron-forge make",
    "electron:package": "electron-forge package",
    "electron:smoke-package": "node scripts/smoke-electron-package.mjs",
    "electron:start": "electron-forge start",
    "electron:verify-package": "node scripts/verify-electron-package.mjs",
    "parity:check": "node scripts/parity/check-completion.mjs",
    "parity:compact": "node scripts/qa/compact-parity-report.mjs",
    "qa:compact": "pnpm typecheck && pnpm test && pnpm test:e2e",
    "qa:compact:electron": "pnpm test:electron",
    "qa:verbose": "GIT_CLIENT_VERBOSE_TESTS=1 pnpm test:e2e",
    "release": "node scripts/publish-release.mjs",
    "release:build": "node scripts/release.mjs",
    "release:dry-run": "node scripts/publish-release.mjs --dry-run",
    "release:validate-local": "node scripts/release.mjs --local-ad-hoc",
    "release:verify-first": "node scripts/verify-first-release.mjs",
    "test": "vitest run --root ../.. apps/git-client",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:electron": "playwright test --config playwright.electron.config.ts",
    "test:electron-package-policy": "node --test scripts/electron-package-policy.node-test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "catalog:",
    "@codemirror/lang-css": "catalog:",
    "@codemirror/lang-html": "catalog:",
    "@codemirror/lang-java": "catalog:",
    "@codemirror/lang-javascript": "catalog:",
    "@codemirror/lang-json": "catalog:",
    "@codemirror/lang-python": "catalog:",
    "@codemirror/language": "catalog:",
    "@codemirror/merge": "catalog:",
    "@codemirror/search": "catalog:",
    "@codemirror/state": "catalog:",
    "@codemirror/view": "catalog:",
    "@tanstack/react-virtual": "catalog:",
    "@vscode/ripgrep": "1.18.0",
    "@xterm/addon-fit": "catalog:",
    "@xterm/xterm": "catalog:",
    "chokidar": "5.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fflate": "0.8.3",
    "lucide-react": "1.25.0",
    "node-pty": "1.1.0",
    "radix-ui": "1.6.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "scheduler": "0.27.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-dmg": "7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.2",
    "@electron-forge/plugin-fuses": "7.11.2",
    "@electron-forge/plugin-vite": "7.11.2",
    "@electron-forge/shared-types": "7.11.2",
    "@electron/fuses": "2.1.3",
    "@electron/rebuild": "4.2.0",
    "@playwright/test": "catalog:",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "26.1.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "ds-store": "0.1.6",
    "electron": "43.1.1",
    "fs-xattr": "0.4.0",
    "macos-alias": "0.2.12",
    "node-gyp": "13.0.1",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "nx": {
    "targets": {
      "release": {
        "inputs": [
          "{projectRoot}/**/*",
          "{workspaceRoot}/.github/workflows/git-client.yml"
        ]
      }
    }
  }
}
