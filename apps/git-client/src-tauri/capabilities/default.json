{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Permissions for the local Git client window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "store:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }]
    }
  ]
}
