{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:recommended",
    "group:monorepos",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],
  "timezone": "Asia/Seoul",
  "enabledManagers": ["pnpm", "github-actions"],
  "labels": ["dependencies"],
  "dependencyDashboardTitle": "Dependency Dashboard",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"]
  },
  "packageRules": [
    {
      "description": "Keep workspace package ranges moving without pinning published package dependencies.",
      "matchManagers": ["pnpm"],
      "rangeStrategy": "bump"
    },
    {
      "description": "Group non-major pnpm dependency updates across the monorepo.",
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "pnpm dependencies",
      "groupSlug": "pnpm-dependencies"
    },
    {
      "description": "Require dashboard approval before opening major pnpm dependency updates.",
      "matchDatasources": ["npm"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Group GitHub Actions updates.",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions"
    }
  ]
}
