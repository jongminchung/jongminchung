{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:recommended",
    "group:monorepos",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],
  "timezone": "Asia/Seoul",
  "enabledManagers": [
    "bun",
    "custom.jsonata",
    "github-actions"
  ],
  "labels": [
    "dependencies"
  ],
  "dependencyDashboardTitle": "Dependency Dashboard",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 4am on monday"
    ]
  },
  "customManagers": [
    {
      "customType": "jsonata",
      "fileFormat": "json",
      "managerFilePatterns": [
        "/(^|/)package\\.json$/"
      ],
      "matchStrings": [
        "$exists(catalog) ? $each(catalog, function($v, $k) { {\"depName\": $k, \"currentValue\": $v, \"depType\": \"catalog\"} }) : []"
      ],
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "description": "Keep workspace package ranges moving without pinning published package dependencies.",
      "matchManagers": [
        "bun"
      ],
      "rangeStrategy": "bump"
    },
    {
      "description": "Group non-major Bun dependency updates across the monorepo.",
      "matchDatasources": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Bun dependencies",
      "groupSlug": "bun-dependencies"
    },
    {
      "description": "Require dashboard approval before opening major Bun dependency updates.",
      "matchDatasources": [
        "npm"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Group GitHub Actions updates.",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions"
    }
  ]
}
