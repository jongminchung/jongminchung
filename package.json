{
  "name": "jongminchung",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm run icon:check && pnpm -r --if-present run build",
    "check": "pnpm run fmt:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "deps:check": "pnpm dlx npm-check-updates --workspaces --target latest --packageManager pnpm",
    "deps:update": "pnpm dlx npm-check-updates -u --workspaces --target latest --packageManager pnpm --reject typescript && pnpm install",
    "dev:docs": "pnpm --filter @jongminchung/docs run dev",
    "dev:readme": "pnpm --filter @jongminchung/readme run dev",
    "fmt": "oxfmt --config .oxfmtrc.mjs .",
    "fmt:check": "oxfmt --config .oxfmtrc.mjs --check .",
    "icon:check": "pnpm --filter @jongminchung/icon run check",
    "icon:generate": "pnpm --filter @jongminchung/icon run generate",
    "lint": "oxlint .",
    "publish:dry-run": "pnpm --filter @jongminchung/remark-plantuml run publish:dry-run && pnpm --filter @jongminchung/tooling run publish:dry-run",
    "test": "vitest run",
    "test:docs": "pnpm --filter @jongminchung/docs run test",
    "test:readme": "pnpm --filter @jongminchung/readme run test:e2e",
    "typecheck": "tsc --noEmit && pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "@jongminchung/tooling": "workspace:*",
    "@nx/devkit": "catalog:",
    "@nx/js": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "nx": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=26.5.0",
    "pnpm": ">=11.13.0"
  },
  "packageManager": "pnpm@11.15.1"
}
